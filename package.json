{
  "name": "easy",
  "displayName": "Easy Language",
  "description": "A VS Code language for visual note-taking with colored tags (#todo, #doing, #done), formatted titles (#, ##, ###), date insertion, and keyboard shortcuts — designed for fast, organized plain-text notes.",
  "version": "0.1.0",
  "publisher": "JorgeDuarte",
  "author": {
    "name": "Jorge Duarte"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-usuario/EasyLanguage"
  },
  "engines": {
    "vscode": "^1.52.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "notes",
    "todo",
    "productivity",
    "easy",
    "color",
    "task management"
  ],
  "activationEvents": [
    "onLanguage:easy"
  ],
  "main": "./extension.js",
  "contributes": {

    "snippets": [
        {
            "language": "easy",
            "path": "./easySnippets.json"
        }
    ],
      "languages": [{
          "id": "easy",
          "aliases": ["Easy", "easy"],
          "extensions": [".easy"],
          "configuration": "./language-configuration.json"
      }],
      "grammars": [{
          "language": "easy",
          "scopeName": "source.easy",
          "path": "./syntaxes/easy.tmLanguage.json"
      }],
      "themes": [
          {
              "label": "Easy Dark",
              "uiTheme": "vs-dark",
              "path": "./themes/easy-color-theme.json"
          },
          {
              "label": "Easy Light",
              "uiTheme": "vs",
              "path": "./themes/easy-light-color-theme.json"
          }
      ],
      "keybindings": [
        
        {
        "command": "extension.insertText",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus"
         },

        {
            "command": "extension.insertSquare",
            "key": "ctrl+alt+i",
            "when": "editorTextFocus"
        },

        {
            "command": "extension.insertCurrentDate",
            "key": "ctrl+alt+f",
            "when": "editorTextFocus"
             }

    ],

    "commands": [
        {
            "command": "extension.insertText",
            "title": "Insert Check Mark"
        },

        {
            "command": "extension.insertSquare",
            "title": "Insert Square"
        },

        {
            "command": "extension.insertCurrentDate",
            "title": "Insert Current Date"
        }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
      "typescript": "^4.1.2",
      "vscode": "^1.1.37",
      "tslint": "^5.0.0",
      "@types/node": "^14.14.10",
      "@types/mocha": "^8.0.4"
  }
}
